# Copie este arquivo para .env.local e preencha os valores antes de rodar
# `npm run dev` ou fazer deploy. Nunca use o prefixo NEXT_PUBLIC_ em
# variáveis que não devem ser expostas ao navegador (ver README).

# Obrigatória para envio real de leads. Server-only — API Route
# (app/api/leads/route.ts) encaminha as solicitações validadas para cá.
# Sem esta variável, a API responde erro real ao usuário (nunca sucesso falso).
LEADS_WEBHOOK_URL=

# Opcional. "true" simula sucesso no envio de leads sem chamar a API — útil
# apenas para demonstrações. Nunca deixe ativado em produção real.
NEXT_PUBLIC_DEMO_MODE=

# Opcional. Número de WhatsApp em formato internacional, apenas dígitos
# (ex.: 5521999999999), usado no CTA "Falar com a Festei" e na página /contato.
# Enquanto vazio, esses links não são renderizados.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Opcional. E-mail exibido na página /contato. Padrão: ola@festei.com.br
NEXT_PUBLIC_CONTACT_EMAIL=
